# Environment for skilldev-site.service
# Install as /etc/skilldev-site.env

SITE_ROOT=/var/www/skilldev-site
SITE_REPO=https://github.com/Geeedy/site.git
SITE_BRANCH=main
SITE_REMOTE=origin

# Production: sync hard to remote (no local drift)
SITE_FORCE_SYNC=1
SITE_REBUILD=1

# build_pages.py
BASE=
NOINDEX=0
SITE=https://skill-dev.ai
SITE_URL=https://skill-dev.ai

# serve_i18n.py
HOST=0.0.0.0
PORT=8080
