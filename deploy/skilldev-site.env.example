# Environment for skilldev-site.service / skilldev-leads-bot.service
# Install as /etc/skilldev-site.env

SITE_ROOT=/var/www/skilldev-site
SITE_REPO=https://github.com/Geeedy/site.git
SITE_BRANCH=main
SITE_REMOTE=origin

# Production: sync hard to remote (no local drift)
SITE_FORCE_SYNC=1
SITE_REBUILD=1

# build_pages.py
BASE=
NOINDEX=0
SITE=https://skill-dev.online
SITE_URL=https://skill-dev.online

# serve_i18n.py
HOST=0.0.0.0
PORT=8080

# Leads Telegram bot (form → authorized chats)
# Set real values in /etc/skilldev-site.env — do not commit secrets.
TELEGRAM_BOT_TOKEN=
LEADS_BOT_PASSWORD=skill-def-get-leads
LEADS_DATA_DIR=/var/lib/skilldev
