# Skill Dev — path-based locales (EN at root, RU under /ru/)
#
# Files: /…/index.html (EN), /ru/…/index.html (RU). No cookie negotiation.
#
# Put the `location` blocks in server { }. Adjust `root` to your deploy path.

# --- server { } ---
# root /var/www/skill-dev;

location = / {
    add_header Content-Language en always;
    add_header Cache-Control "public, max-age=300" always;
    try_files /index.html =404;
}

# Russian tree
location ^~ /ru/ {
    add_header Content-Language ru always;
    add_header Cache-Control "public, max-age=300" always;
    try_files $uri $uri/ $uri/index.html =404;
}

location = /ru {
    return 301 /ru/;
}

# English (and other) HTML directories
location ~ ^(?<dir>.+)/$ {
    add_header Content-Language en always;
    add_header Cache-Control "public, max-age=300" always;
    try_files $dir/index.html =404;
}

location ~* \.(css|js|png|jpg|jpeg|svg|ico|webp|woff2?)$ {
    add_header Cache-Control "public, max-age=86400" always;
    try_files $uri =404;
}
